{
  "name": "generated-files-bot",
  "version": "1.0.0",
  "description": "Detect modifications to templated files",
  "private": true,
  "author": "Google LLC.",
  "license": "Apache-2.0",
  "repository": "https://github.com/googleapis/repo-automation-bots.git",
  "homepage": "https://github.com/googleapis/repo-automation-bots",
  "bugs": "https://github.com/googleapis/repo-automation-bots/issues",
  "main": "build/src/app.js",
  "keywords": [
    "probot",
    "github",
    "probot-app"
  ],
  "files": [
    "build/src"
  ],
  "scripts": {
    "compile": "tsc -p .",
    "start": "node ./build/src/server.js",
    "start:local": "node ./build/src/local.js",
    "pretest": "npm run compile",
    "test": "cross-env LOG_LEVEL=fatal c8 mocha --exit build/test --timeout 10000",
    "test:snap": "SNAPSHOT_UPDATE=1 npm test",
    "fix": "gts fix",
    "lint": "gts check"
  },
  "dependencies": {
    "@google-automations/bot-config-utils": "^9.0.0",
    "@google-automations/issue-utils": "^5.0.0",
    "gcf-utils": "^17.1.2",
    "js-yaml": "^4.3.0",
    "jsonpath": "^1.2.0",
    "minimatch": "^10.2.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/jsonpath": "^0.2.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/sinon": "^10.0.13",
    "c8": "^7.12.0",
    "cross-env": "^7.0.3",
    "gts": "^4.0.0",
    "mocha": "^10.0.0",
    "nock": "^13.2.9",
    "node-fetch": "^2.6.0",
    "sinon": "^15.0.0",
    "snap-shot-it": "^7.4.1",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">= 22"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "jsonpath": {
      "underscore": "^1.13.8"
    },
    "qs": "6.15.2",
    "serialize-javascript": "^7.0.5",
    "tmp": "0.2.7",
    "uuid": "^11.1.1",
    "protobufjs": "^7.6.5",
    "@opentelemetry/core": "2.8.0",
    "@opentelemetry/sdk-trace-base": "2.8.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/context-async-hooks": "2.8.0",
    "js-yaml": "^4.3.0",
    "body-parser": "^1.20.6 || ^2.3.0",
    "brace-expansion": "^1.1.16 || ^2.1.2 || ^5.0.7"
  }
}
